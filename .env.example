BOT_TOKEN=
CHAT_ID=

# Optional. Get a free key at https://tequila.kiwi.com to enable
# Kiwi.com as a second search provider alongside Google Flights.
# Leave blank to search Google Flights only.
KIWI_API_KEY=

# Optional extra providers - each is a no-op until its key(s) are set.
# See app/providers/*.py for setup notes on each.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
DUFFEL_API_KEY=
SKYSCANNER_API_KEY=

CHECK_INTERVAL=1
DATABASE_PATH=data/flights.db
TIMEZONE=Asia/Riyadh
LOG_LEVEL=INFO

# --- Notification rules (Sprint 2) ---
# Alert if price drops by at least this % since the last check.
PRICE_DROP_THRESHOLD_PCT=10.0
# A new-lowest beating the old lowest by this % is an escalated alert
# (bypasses quiet hours).
ESCALATION_DROP_THRESHOLD_PCT=30.0
# "Flash deal": price is at least this % below the route's own
# historical average, even if it's not a new all-time low or a big
# drop since the last check. Escalated (bypasses quiet hours).
FLASH_DEAL_DROP_PCT=25.0
# Don't repeat an alert unless the price has moved by at least this %
# since the price last actually alerted on. Stops a flight sitting
# under target (or bouncing by a dollar or two) from re-firing every
# single scheduled check.
DEDUP_TOLERANCE_PCT=3.0
# Suppress non-escalated alerts between these local hours (0-23).
# Leave both at 0 to disable quiet hours.
QUIET_HOURS_START=0
QUIET_HOURS_END=0
# How many days of history to consider for analytics/recommendations.
ANALYTICS_WINDOW_DAYS=45
