BOT_TOKEN=
CHAT_ID=

# Optional. Get a free key at https://tequila.kiwi.com to enable
# Kiwi.com as a second search provider alongside Google Flights.
# Leave blank to search Google Flights only.
KIWI_API_KEY=

# Optional extra providers - each is a no-op until its key(s) are set.
# See app/providers/*.py for setup notes on each.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
DUFFEL_API_KEY=
# Actually a RapidAPI key for the unofficial "Sky Scrapper" API
# (rapidapi.com/apiheya/api/sky-scrapper) - Skyscanner itself has no
# self-serve signup. Free tier is only 20 requests/month, so this
# provider is only used for manual checks, never the hourly scheduler.
SKYSCANNER_API_KEY=

CHECK_INTERVAL=1
DATABASE_PATH=data/flights.db
TIMEZONE=Asia/Riyadh
LOG_LEVEL=INFO

# --- WhatsApp alerts (optional, via Twilio) ---
# TWILIO_SID/TWILIO_TOKEN, a sender number, and WHATSAPP_TO must all
# be set for WhatsApp alerts to go out alongside Telegram ones. Get
# TWILIO_SID/TWILIO_TOKEN from https://console.twilio.com (WhatsApp
# sandbox is free for testing). WA_FROM is Twilio's WhatsApp-enabled
# sender number (the sandbox number, e.g. whatsapp:+14155238886, or
# your approved WhatsApp Business sender) - preferred over
# TWILIO_PHONE, which is only used as a fallback and may not actually
# be WhatsApp-enabled. WHATSAPP_TO is your own number, in E.164 format
# e.g. +9665XXXXXXXX. If using the Sandbox, WHATSAPP_TO must first
# send the sandbox's "join <code>" message on WhatsApp before it can
# receive anything.
TWILIO_SID=
TWILIO_TOKEN=
WA_FROM=
TWILIO_PHONE=
WHATSAPP_TO=

# --- Notification rules (Sprint 2) ---
# Alert if price drops by at least this % since the last check.
PRICE_DROP_THRESHOLD_PCT=10.0
# A new-lowest beating the old lowest by this % is an escalated alert
# (bypasses quiet hours).
ESCALATION_DROP_THRESHOLD_PCT=30.0
# "Flash deal": price is at least this % below the route's own
# historical average, even if it's not a new all-time low or a big
# drop since the last check. Escalated (bypasses quiet hours).
FLASH_DEAL_DROP_PCT=25.0
# Don't repeat an alert unless the price has moved by at least this %
# since the price last actually alerted on. Stops a flight sitting
# under target (or bouncing by a dollar or two) from re-firing every
# single scheduled check.
DEDUP_TOLERANCE_PCT=3.0
# Suppress non-escalated alerts between these local hours (0-23).
# Leave both at 0 to disable quiet hours.
QUIET_HOURS_START=0
QUIET_HOURS_END=0
# How many days of history to consider for analytics/recommendations.
ANALYTICS_WINDOW_DAYS=45
# A "rebound" alert (price returned after increasing) needs both the
# prior rise and the current fall to be at least this % each.
REBOUND_MIN_CHANGE_PCT=3.0

# --- Provider reliability (Roadmap Phase 1) ---
# Per-attempt timeout for a single provider's search() call.
PROVIDER_TIMEOUT_SECONDS=15.0
# Extra attempts after the first on timeout/network errors (not on a
# provider's own "no flights found"). 2 = 3 attempts total.
PROVIDER_MAX_RETRIES=2
# Base delay before the first retry; doubles each subsequent retry.
PROVIDER_RETRY_BACKOFF_SECONDS=1.0
# Consecutive failures before a provider is auto-disabled (skipped
# entirely) until the cooldown below passes.
PROVIDER_FAILURE_THRESHOLD=5
PROVIDER_DISABLE_COOLDOWN_MINUTES=30
